{
  "name": "@antelopejs/mongodb",
  "version": "0.1.1",
  "description": "MongoDB module that implements the Database interface of antelopejs",
  "keywords": [
    "antelopejs",
    "mongodb",
    "database",
    "nosql",
    "orm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntelopeJS/mongodb.git"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "biome format --write .",
    "generate": "ajs module exports generate",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm run build",
    "prepare": "ajs module imports install",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && release-it",
    "test": "npx tsc && ajs module test"
  },
  "antelopeJs": {
    "exportsPath": "dist/interfaces",
    "imports": [
      "core@beta",
      "database@beta"
    ],
    "importsOptional": [],
    "defaultConfig": {
      "url": "mongodb://localhost:27017"
    },
    "test": {
      "project": "src/test/testproject.js",
      "folder": "dist/test"
    }
  },
  "dependencies": {
    "mongodb": "^6.15.0",
    "randomstring": "^1.3.1",
    "reflect-metadata": "^0.2.2",
    "uuid": "^11.1.0",
    "chai": "^4.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "rimraf": "^6.0.1",
    "@types/node": "^22.14.1",
    "@types/randomstring": "^1.3.0",
    "@types/chai": "^4.3.3",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^17.0.4",
    "release-it": "^19.0.2",
    "release-it-changelogen": "^0.1.0",
    "typescript": "^5.8.3",
    "mongodb-memory-server-core": "^10.1.4",
    "sinon": "^20.0.0"
  }
}
